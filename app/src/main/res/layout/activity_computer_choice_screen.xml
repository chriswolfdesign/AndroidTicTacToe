<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".ComputerChoiceScreen">

    <TextView
        android:id="@+id/computerPlayerChoiceHeaderText"
        android:layout_height="100dp"
        android:layout_width="match_parent"
        android:textColor="@color/white"
        android:textSize="35sp"
        android:text="@string/computerPlayerChoiceHeaderText" />

    <Button
        android:id="@+id/playerXButton"
        android:layout_width="match_parent"
        android:layout_height="60sp"
        android:layout_below="@id/computerPlayerChoiceHeaderText"
        android:layout_marginTop="70dp"
        style="@style/buttonStyle"
        android:text="@string/playerXText"
        />

    <Button
        android:id="@+id/playerOButton"
        android:layout_width="match_parent"
        android:layout_height="60sp"
        android:layout_below="@id/playerXButton"
        android:layout_marginTop="20dp"
        style="@style/buttonStyle"
        android:text="@string/playerOText"
        />


</RelativeLayout>